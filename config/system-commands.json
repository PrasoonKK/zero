{
  "patterns": [
    {"regex": "(?:what(?:'s|\\s+is)?\\s+(?:the\\s+)?)?\\btime\\b(?:\\s+is\\s+it)?", "action": "time"},
    {"regex": "(?:what(?:'s|\\s+is)?\\s+(?:the\\s+)?)?\\b(?:date|today)\\b", "action": "date"},
    {"regex": "weather|temperature|forecast|how(?:'s|\\s+is)\\s+(?:the\\s+)?(?:weather|outside)", "action": "weather"},

    {"regex": "(?:find|search(?:\\s+for)?|locate|look\\s+for)\\s+(?:file[s]?\\s+(?:named?|called)\\s+)?(.+?)(?:\\s+in\\s+(.+))?$", "action": "find_files", "capture": 1, "captureDir": 2},

    {"regex": "(?:(?:increase|raise|boost)\\s+(?:the\\s+)?brightness)", "action": "brightness", "captureAlt": "up"},
    {"regex": "(?:decrease|lower|dim)\\s+(?:the\\s+)?brightness", "action": "brightness", "captureAlt": "down"},
    {"regex": "brightness\\s+(up|down|\\d+%?)", "action": "brightness", "capture": 1},

    {"regex": "(?:increase|raise|louder|turn\\s+up)\\s+(?:the\\s+)?(?:volume|sound)", "action": "volume", "captureAlt": "up"},
    {"regex": "(?:decrease|lower|quieter|mute|turn\\s+down)\\s+(?:the\\s+)?(?:volume|sound)", "action": "volume", "captureAlt": "down"},
    {"regex": "(?:(?:turn|set)\\s+(?:the\\s+)?)?volume\\s+(up|down|\\d+)", "action": "volume", "capture": 1},

    {"regex": "git\\s+status(?:\\s+(?:in|at|for)\\s+(.+))?", "action": "git_status"},
    {"regex": "git\\s+log(?:\\s+(?:in|at|for)\\s+(.+))?", "action": "git_log"},
    {"regex": "git\\s+diff(?:\\s+(?:in|at|for)\\s+(.+))?", "action": "git_diff"},
    {"regex": "git\\s+branches?(?:\\s+(?:in|at|for)\\s+(.+))?", "action": "git_branches"},
    {"regex": "(?:generate|suggest|write|create|give\\s+me\\s+a?)\\s+commit\\s+message(?:\\s+(?:in|at|for)\\s+(.+))?", "action": "git_commit_msg"},

    {"regex": "(?:(?:can\\s+you\\s+)?(?:please\\s+)?)?open\\s+(?:up\\s+)?(.+)", "action": "open_app", "capture": 1},
    {"regex": "(?:launch|start|run)\\s+(.+)", "action": "open_app", "capture": 1},

    {"regex": "(?:take\\s+a?\\s*|capture\\s+a?\\s*)?screenshot", "action": "screenshot"},

    {"regex": "(?:read|what(?:'s|\\s+is)\\s+(?:in|on))\\s+(?:my\\s+)?clipboard", "action": "clipboard_read"},
    {"regex": "copy\\s+(?:that|last\\s+(?:response|message|answer))", "action": "clipboard_copy_last"},

    {"regex": "remind\\s+me\\s+in\\s+(\\d+\\s*(?:min(?:utes?)?|h(?:ours?)?|seconds?))(?:\\s+to\\s+(.+))?", "action": "reminder", "capture": 1, "captureTask": 2},
    {"regex": "set\\s+(?:a\\s+)?(?:timer|alarm|reminder)\\s+(?:for\\s+)?(\\d+\\s*(?:min(?:utes?)?|h(?:ours?)?))(?:\\s+to\\s+(.+))?", "action": "reminder", "capture": 1, "captureTask": 2},

    {"regex": "(?:system\\s+(?:stats?|info(?:rmation)?|status|health)|how(?:'s|\\s+is)\\s+(?:my\\s+)?(?:cpu|ram|memory|disk|computer|pc|system))", "action": "sysinfo"},
    {"regex": "(?:cpu|ram|memory|disk)\\s+(?:usage|load|status)", "action": "sysinfo"},

    {"regex": "(?:remember|note|save|store)(?:\\s+that)?\\s+(.+)", "action": "remember", "capture": 1},
    {"regex": "(?:what\\s+do\\s+you\\s+(?:know|remember)|show\\s+(?:my\\s+)?memories?|recall\\s+(?:everything|all))", "action": "show_memories"},
    {"regex": "(?:forget|delete|clear)\\s+(?:all\\s+)?(?:my\\s+)?memories?", "action": "clear_memories"},

    {"regex": "^(?:quit|exit|close|goodbye|bye)$", "action": "quit"}
  ]
}
