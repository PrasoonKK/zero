{
  "name": "zero-ai-assistant",
  "version": "1.0.0",
  "description": "Zero — Free, local-first AI desktop assistant",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "build:win": "electron-vite build && electron-builder --win",
    "build:dir": "electron-vite build && electron-builder --dir",
    "release": "electron-vite build && electron-builder --win --publish always",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.7",
    "msedge-tts": "^2.0.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-syntax-highlighter": "^15.5.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-syntax-highlighter": "^15.5.11",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.0"
  },
  "allowScripts": {
    "electron@28.3.3": true,
    "esbuild@0.21.5": true,
    "electron-builder@24.9.1": true,
    "electron-updater@6.1.7": true,
    "msedge-tts@2.0.6": true
  }
}
